// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────

model Sim {
  id            String    @id @default(uuid()) @db.Uuid
  phoneNumber   String    @unique @map("phone_number") @db.VarChar(15)
  imsi          String?   @unique @db.VarChar(15)
  contractCode  String?   @map("contract_code") @db.VarChar(50)
  productCode   String    @map("product_code") @db.VarChar(50)
  masterSimCode String?   @map("master_sim_code") @db.VarChar(20)
  systemStatus  String?   @map("system_status") @db.VarChar(20)
  /// 1 = Mới, 2 = Đã hoạt động, 3 = Đã xác nhận
  status        Int       @default(1)
  usedMB        Int       @default(0) @map("used_mb")
  firstUsedAt   DateTime? @map("first_used_at")
  confirmedAt   DateTime? @map("confirmed_at")
  createdAt     DateTime  @map("created_at") @db.Date
  note          String?   @db.Text
  syncedAt      DateTime? @map("synced_at")

  simType Int @default(0) @map("sim_type") // 0 = M2M, 1 = e-sim

  // ── SOG (nhóm gói cước từ Vinaphone) ─────────────────────────────────────
  sogGroupId   String?  @map("sog_group_id") @db.VarChar(50)
  sogGroupName String?  @map("sog_group_name") @db.VarChar(255)
  sogMaGoi     String?  @map("sog_ma_goi") @db.VarChar(100)
  /**
   * true = chủ nhóm (msisdn_chu_nhom IS NULL); false = thành viên; null = không có sog
   */
  sogIsOwner   Boolean? @map("sog_is_owner")

  customerName String?   @map("customer_name") @db.VarChar(255)
  customerCode String?   @map("customer_code") @db.VarChar(100)
  contractInfo String?   @map("contract_info") @db.Text
  contractDate DateTime? @map("contract_date") @db.Date

  provinceCode String? @map("province_code") @db.VarChar(20)

  ratingPlanId   Int?    @map("rating_plan_id") @db.Integer
  ratingPlanName String? @map("rating_plan_name") @db.VarChar(255)

  groupName String? @map("group_name") @db.VarChar(255)

  usageHistory      UsageHistory[]
  simGroups         SimGroup[]
  alertChecks       AlertCheck[]
  alertConfigs      AlertConfig[]
  contracts         Contract[]         @relation("ContractSims")
  monthlyDataUsages MonthlyDataUsage[]
  ratingPlan        RatingPlan?        @relation(fields: [ratingPlanId], references: [ratingPlanId], onDelete: SetNull)

  @@map("sims")
}

model UsageHistory {
  id     String @id @default(uuid()) @db.Uuid
  simId  String @map("sim_id") @db.Uuid
  month  String @db.Char(7)
  usedMB Int    @default(0) @map("used_mb")

  sim Sim @relation(fields: [simId], references: [id], onDelete: Cascade)

  @@unique([simId, month])
  @@map("usage_history")
}

model MasterSim {
  id                String    @id @default(uuid()) @db.Uuid
  code              String    @unique @db.VarChar(20)
  phoneNumber       String    @unique @map("phone_number") @db.VarChar(15)
  packageName       String    @map("package_name") @db.VarChar(100)
  packageCapacityMB Int       @map("package_capacity_mb")
  usedMB            Int       @default(0) @map("used_mb")
  description       String?   @db.Text
  syncedAt          DateTime? @map("synced_at")

  @@map("master_sims")
}

model Group {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(dbgenerated("CURRENT_DATE")) @map("created_at") @db.Date

  simGroups    SimGroup[]
  alertConfigs AlertConfig[]

  @@map("groups")
}

model GroupSim {
  id       String @id @default(uuid()) @db.Uuid
  groupId  Int    @unique @map("group_id") @db.Integer
  name     String @map("name") @db.VarChar(100)
  groupKey String @unique @map("group_key") @db.VarChar(50)
}

model SimGroup {
  simId   String @map("sim_id") @db.Uuid
  groupId String @map("group_id") @db.Uuid

  sim   Sim   @relation(fields: [simId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([simId, groupId])
  @@map("sim_groups")
}

model AlertConfig {
  id           String   @id @default(uuid()) @db.Uuid
  label        String   @db.VarChar(200)
  thresholdMB  Int      @map("threshold_mb")
  simId        String?  @map("sim_id") @db.Uuid
  groupId      String?  @map("group_id") @db.Uuid
  productCode  String?  @map("product_code") @db.VarChar(50)
  ratingPlanId Int?     @map("rating_plan_id") @db.Integer
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")

  sim         Sim?         @relation(fields: [simId], references: [id], onDelete: Cascade)
  group       Group?       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  alertChecks AlertCheck[]

  @@map("alert_configs")
}

model AlertCheck {
  id        String    @id @default(uuid()) @db.Uuid
  simId     String    @map("sim_id") @db.Uuid
  alertId   String    @map("alert_id") @db.Uuid
  checked   Boolean   @default(false)
  checkedAt DateTime? @map("checked_at")
  checkedBy String?   @map("checked_by") @db.VarChar(100)

  sim   Sim         @relation(fields: [simId], references: [id], onDelete: Cascade)
  alert AlertConfig @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@unique([simId, alertId])
  @@map("alert_checks")
}

// Thành viên trong nhóm gói cước của Vinaphone (cached từ API memberOfGr)
model SimGroupMember {
  id             String    @id @default(uuid()) @db.Uuid
  groupId        String    @map("group_id") @db.VarChar(50)
  msisdn         String    @db.VarChar(15)
  ratingPlanName String?   @map("rating_plan_name") @db.VarChar(255)
  status         Int?
  syncedAt       DateTime? @map("synced_at")

  @@unique([groupId, msisdn])
  @@map("sim_group_members")
}

model RatingPlan {
  id           String    @id @default(uuid()) @db.Uuid
  ratingPlanId Int       @unique @map("rating_plan_id") @db.Integer
  code         String    @unique @db.VarChar(50)
  name         String    @db.VarChar(255)
  syncedAt     DateTime? @map("synced_at")

  sims Sim[]

  @@map("rating_plans")
}

model Customer {
  id           String     @id @default(uuid()) @db.Uuid
  customerName String     @map("customer_name") @db.VarChar(255)
  customerCode String     @unique @map("customer_code") @db.VarChar(100)
  syncedAt     DateTime?  @map("synced_at")
  contracts    Contract[]

  @@map("customers")
}

model Contract {
  id             String    @id @default(uuid()) @db.Uuid
  contractId     Int       @unique @map("contract_id") @db.Integer
  contractCode   String    @unique @map("contract_code") @db.VarChar(50)
  contractDate   DateTime? @map("contract_date") @db.Date
  syncedAt       DateTime? @map("synced_at")
  contractor     String?   @map("contractor") @db.VarChar(50)
  customerName   String?   @map("customer_name") @db.VarChar(255)
  centerCode     String?   @map("center_code") @db.VarChar(20)
  customerCode   String?   @map("customer_code") @db.VarChar(100)
  contactPhone   String?   @map("contact_phone") @db.VarChar(20)
  contactAddress String?   @map("contact_address") @db.Text
  paymentName    String?   @map("payment_name") @db.VarChar(255)
  paymentAddress String?   @map("payment_address") @db.Text
  routeCode      String?   @map("route_code") @db.VarChar(50)
  birthday       DateTime? @map("birthday") @db.Date

  // Quan hệ với Sim (1 contract có thể có nhiều sim)
  sims     Sim[]     @relation("ContractSims")
  customer Customer? @relation(fields: [customerCode], references: [customerCode], onDelete: SetNull)

  @@map("contracts")
}

model MonthlyDataUsage {
  id                String @id @default(uuid()) @db.Uuid
  msisdn            String @db.VarChar(15)
  month             String @db.Char(7) // "YYYY-MM"
  smsNoiMangUsed    Int?   @map("sms_noi_mang_used")
  smsNgoaiMangUsed  Int?   @map("sms_ngoai_mang_used")
  dataUsedMB        Int?   @map("data_used_mb")
  smsQuocTeUsed     Int?   @map("sms_quoc_te_used")
  totalData         Int?   @map("total_data")
  totalSmsNoiMang   Int?   @map("total_sms_noi_mang")
  totalSmsNgoaiMang Int?   @map("total_sms_ngoai_mang")
  totalSmsQuocTe    Int?   @map("total_sms_quoc_te_used")

  sim Sim @relation(fields: [msisdn], references: [phoneNumber], onDelete: Cascade)

  @@unique([msisdn, month])
  @@map("monthly_data_usage")
}
